root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

[*.{kt,kts}]
indent_size = 4
max_line_length = 120
# Compose functions are capitalized by convention — suppress the naming rule for annotated functions
ktlint_function_naming_ignore_when_annotated_with = Composable

[*.{xml,json,yml,yaml,toml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
