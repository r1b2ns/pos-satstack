<?xml version="1.0" encoding="utf-8"?>
<!--
     Controls what may be uploaded to cloud backup / transferred during device
     migration. Both the mnemonic prefs and the wallet descriptor prefs stay
     on the device — there is no safe way to back them up automatically, and
     the user's external BIP-39 backup is the recovery path.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="mnemonic_secure_prefs.xml" />
        <exclude domain="sharedpref" path="wallet_secure_prefs.xml" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="mnemonic_secure_prefs.xml" />
        <exclude domain="sharedpref" path="wallet_secure_prefs.xml" />
    </device-transfer>
</data-extraction-rules>
